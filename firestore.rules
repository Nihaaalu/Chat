rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Fallback/Safety net
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    // Config security document
    match /config/security {
      allow read, write: if true;
    }

    // Chat rooms
    match /chat/{roomCode} {
      allow read, write: if request.auth != null;
      
      match /messages/{messageId} {
        allow read, write: if request.auth != null;
      }
    }

    // Temporary private rooms
    match /privateRooms/{roomCode} {
      allow read, write: if request.auth != null;

      match /messages/{messageId} {
        allow read, write: if request.auth != null;
      }
    }

    // Matchmaking waiting queue
    match /waitingQueue/{uid} {
      allow read, write: if request.auth != null;
    }

    match /waitingQueue {
      allow read, write: if request.auth != null;
    }

    // Temporary random sessions
    match /randomSessions/{sessionId} {
      allow read, write: if request.auth != null;

      match /messages/{messageId} {
        allow read, write: if request.auth != null;
      }
    }

    // Presence updates
    match /presence/{uid} {
      allow read, write: if request.auth != null;
    }

    // Settings
    match /settings/{uid} {
      allow read, write: if request.auth != null;
    }
  }
}
