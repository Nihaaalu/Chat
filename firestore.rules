rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default-deny catch-all safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Config security document for passphrase hashing
    match /config/security {
      allow read, write: if true;
    }

    // Chat document room code "1317" and "RUBY-CARR"
    match /chat/{roomCode} {
      allow read, write: if roomCode == "1317" || roomCode == "RUBY-CARR";

      // Subcollection messages
      match /messages/{messageId} {
        allow read, write: if roomCode == "1317" || roomCode == "RUBY-CARR";
      }
    }

    // Temporary private rooms
    match /privateRooms/{roomCode} {
      allow read, write: if true;

      match /messages/{messageId} {
        allow read, write: if true;
      }
    }

    // Matchmaking waiting queue
    match /waitingQueue/{uid} {
      allow read, write: if true;
    }

    match /waitingQueue {
      allow read, write: if true;
    }

    // Temporary random sessions
    match /randomSessions/{sessionId} {
      allow read, write: if true;

      match /messages/{messageId} {
        allow read, write: if true;
      }
    }

    // Presence updates
    match /presence/{uid} {
      allow read, write: if true;
    }

    // Settings
    match /settings/{uid} {
      allow read, write: if true;
    }
  }
}
