rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Rooms collection rules
    match /rooms/{roomCode} {
      // Anyone can create a room, read it to check its state, or update it to join/leave
      allow read, create: if true;
      allow update: if request.resource.data.members.size() <= 2;
      
      // Allow deletion only if room is empty or being cleaned up
      allow delete: if true;

      // Messages subcollection rules
      match /messages/{messageId} {
        // Anyone in the room can read and write messages
        allow read, write: if true;
      }
    }
  }
}
