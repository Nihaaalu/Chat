rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Safety fallback: allow public read/write to prevent any Auth initialization race conditions
    match /{document=**} {
      allow read, write: if true;
    }

    // Chat room rules
    match /chat/{roomId} {
      allow read, write: if true;
      
      match /messages/{messageId} {
        allow read, write: if true;
      }
    }

    // Private rooms rules
    match /privateRooms/{roomId} {
      allow read, write: if true;

      match /messages/{messageId} {
        allow read, write: if true;
      }
    }

    // Matchmaking queue rules
    match /waitingQueue/{uid} {
      allow read, write: if true;
    }

    match /waitingQueue {
      allow read, write: if true;
    }

    // Random session rules
    match /randomSessions/{sessionId} {
      allow read, write: if true;

      match /messages/{messageId} {
        allow read, write: if true;
      }
    }
  }
}
